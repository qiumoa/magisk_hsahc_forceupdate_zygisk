# 目标包名
target_package=com.lta.hsahc.aligames

# 目标库相对路径（相对于 /data/app/.../<pkg-随机>/）
target_lib_relpath=lib/arm64/libil2cpp.so

# 挂载重试次数与间隔（启动后）
retry_count=180
retry_interval_sec=1

# 是否严格校验哈希：1=是，0=否
strict_sha256_check=1

# 当前适配版本的原始 / 补丁后 libil2cpp.so 哈希
orig_libil2cpp_sha256=7a9fdc8f621c39246c77cd02d8f291f2f26c6d3cee0da9b1820f67e1d954922b
patched_libil2cpp_sha256=29a506d5f2cc58a7ae8f34041e889fab57bcba8a40e8cbb33d17e9b6cfa2e7c9
